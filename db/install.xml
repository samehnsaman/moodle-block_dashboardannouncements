<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/dashboardannouncements/db" VERSION="2026041900" COMMENT="XMLDB file for block_dashboardannouncements"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>
        <TABLE NAME="block_dashboardannouncements" COMMENT="Announcement records">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="message" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="draft" SEQUENCE="false"/>
                <FIELD NAME="timestart" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timeend" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="targettype" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="all" SEQUENCE="false"/>
                <FIELD NAME="targetconfigjson" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="sendmode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="none" SEQUENCE="false"/>
                <FIELD NAME="archived" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="firstdeliveryqueued" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="modifiedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="statusarch_idx" UNIQUE="false" FIELDS="status, archived"/>
                <INDEX NAME="timewindow_idx" UNIQUE="false" FIELDS="timestart, timeend"/>
                <INDEX NAME="created_idx" UNIQUE="false" FIELDS="timecreated"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="block_dashboardannouncements_delqueue" COMMENT="Announcement delivery queue">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="announcementid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="channel" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="message" SEQUENCE="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
                <FIELD NAME="recipientsnapshotcount" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="attempts" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="lasterror" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="timestarted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="timefinished" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="announcement_fk" TYPE="foreign" FIELDS="announcementid" REFTABLE="block_dashboardannouncements" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="status_idx" UNIQUE="false" FIELDS="status, timecreated"/>
                <INDEX NAME="announcement_idx" UNIQUE="false" FIELDS="announcementid"/>
            </INDEXES>
        </TABLE>
        <TABLE NAME="block_dashboardannouncements_dellog" COMMENT="Announcement delivery log per user and channel">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="queueid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="announcementid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="channel" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="message" SEQUENCE="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false"/>
                <FIELD NAME="messageid" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="errorinfo" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="timeprocessed" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="queue_fk" TYPE="foreign" FIELDS="queueid" REFTABLE="block_dashboardannouncements_delqueue" REFFIELDS="id"/>
                <KEY NAME="announcement_fk" TYPE="foreign" FIELDS="announcementid" REFTABLE="block_dashboardannouncements" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="unique_send_idx" UNIQUE="true" FIELDS="announcementid, userid, channel"/>
                <INDEX NAME="announcement_status_idx" UNIQUE="false" FIELDS="announcementid, status"/>
                <INDEX NAME="queue_idx" UNIQUE="false" FIELDS="queueid"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>
